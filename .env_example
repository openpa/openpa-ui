# Dev server port
# - Electron mode: defaults to 0 (random available port)
# - Web mode: defaults to 8000
# PORT=8000

# Default A2A Agent URL
# - Web dev mode: /a2a requests are proxied to this address
# - Electron mode: configurable in Settings UI (stored in localStorage)
# - Default: http://localhost:10000
# AGENT_URL=http://localhost:10000

# Agent URL for Vite (loaded by vite configs but not currently used by the client)
# VITE_AGENT_URL=http://localhost:10000
